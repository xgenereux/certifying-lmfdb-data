import CertifyingLmfdbData.Polynomial.Tactic

/-! PROFILING: p = X^6 - 2*X - 2, mixed complex root, 100000-digit precision. -/
open Polynomial
namespace Test100000

noncomputable def p : Polynomial ℚ := X^6 - 2*X - 2

def v : Fin 2 → ℝ := ![0., 1.]

def M : Matrix (Fin 2) (Fin 2) ℝ :=
  !![ 0., -0.;
      0., 0. ]

set_option maxHeartbeats 4000000 in
set_option profiler true in
noncomputable def prof : UniqueRootNear p (toComplex v) 1e-99997 := by
  unique_root_near M

end Test100000
