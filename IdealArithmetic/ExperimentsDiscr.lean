def DiscrOfPseudoRemainderCoeff {R : Type*} [CommRing R] [LinearOrder R] (P : List (List R)) (f : List R)
  (i : ℕ) : R :=
    if H : i + 2 < P.length ∧ i < f.length then
      (-1) ^ ((P[i].length) * (P[i + 1].length - 1)) * ((P[i + 1].getLastD 0) ^ (P[i].length  - P[i + 2].length)) * ((f[i]) ^ ((P[i + 1]).length - 1))
    else 0

def DiscrOfPseudoRemainder {R : Type*} [CommRing R] [Div R] [LinearOrder R] [Inhabited R]
  (P : List (List R)) (e : List R) (f : List R) :=
    if hlen : (2 ≤ P.length ∧ P.length ≤ e.length + 2) then
      (-1) ^ (((P[0].length - 1) * (P[0].length - 2)) / 2 ) *
      (((∏ (i : Fin (P.length - 2)), DiscrOfPseudoRemainderCoeff P f i)) *
      ((P.getLastD 0).getLastD 0) ^ (P[P.length - 2].length - 1)) / (∏ (i : Fin (P.length - 2)), e[i] ^ ((P[i.val + 1]).length - 1))
    else 0


