section DiscriminantMod


variable {R : Type*} [CommRing R] [DecidableEq R]

def Resultant_1_1 (a0 b0 : R) := b0 - a0

def Resultant_2_1 (a0 a1 b0 : R) := b0^2 + (-a1)*b0 + a0

def Resultant_2_2 (a0 a1 b0 b1 : R) :=
  b0^2 + (-a1)*b0*b1 + a0*b1^2 + (a1^2 - 2*a0)*b0 + (-a0*a1)*b1 + a0^2

def Resultant_3_2 (a0 a1 a2 b0 b1 : R) :=
  b0^3 + (-a2)*b0^2*b1 + a1*b0*b1^2 + (-a0)*b1^3 + (a2^2 - 2*a1)*b0^2 +
  (-a1*a2 + 3*a0)*b0*b1 + a0*a2*b1^2 + (a1^2 - 2*a0*a2)*b0 + (-a0*a1)*b1 + a0^2

def Resultant_3_3 (a0 a1 a2 b0 b1 b2 : R) :=
    b0^3 + (-a2)*b0^2*b1 + a1*b0*b1^2 + (-a0)*b1^3 + (a2^2 - 2*a1)*b0^2*b2 + (-a1*a2 + 3*a0)*b0*b1*b2 +
    a0*a2*b1^2*b2 + (a1^2 - 2*a0*a2)*b0*b2^2 + (-a0*a1)*b1*b2^2 + a0^2*b2^3 + (-a2^3 + 3*a1*a2 - 3*a0)*b0^2 +
    (a1*a2^2 - 2*a1^2 - a0*a2)*b0*b1 + (-a0*a2^2 + 2*a0*a1)*b1^2 + (-a1^2*a2 + 2*a0*a2^2 + a0*a1)*b0*b2 +
    (a0*a1*a2 - 3*a0^2)*b1*b2 + (-a0^2*a2)*b2^2 + (a1^3 - 3*a0*a1*a2 + 3*a0^2)*b0 +
    (-a0*a1^2 + 2*a0^2*a2)*b1 + a0^2*a1*b2 - a0^3


lemma resultant_1_1 {a0 b0 : R}:
  resultant (ofList [a0, 1]) (ofList [b0, 1])
    = Resultant_1_1 a0 b0 := by sorry

lemma resultant_2_1 {a0 a1 b0 : R}:
  resultant ( ofList [a0, a1, 1]) (ofList [b0, 1])
    = Resultant_2_1 a0 a1 b0 := by sorry

lemma resultant_2_2 {a0 a1 b0 b1 : R}:
  resultant ( ofList [a0, a1, 1]) (ofList [b0, b1, 1])
    = Resultant_2_2 a0 a1 b0 b1 := by sorry

lemma resultant_3_2 {a0 a1 a2 b0 b1 : R}:
  resultant (ofList [a0, a1, a2, 1]) (ofList [b0, b1, 1])
    = Resultant_3_2 a0 a1 a2 b0 b1 := by sorry

lemma resultant_3_3 {a0 a1 a2 b0 b1 b2 : R}:
  resultant (ofList [a0, a1, a2, 1]) (ofList [b0, b1, b2, 1])
    = Resultant_3_3 a0 a1 a2 b0 b1 b2 := by sorry

lemma discriminant_2 {a0 a1 : R} : discriminant ( ofList [a0, a1, 1]) = a1 ^ 2 - 4 * a0 := by sorry



lemma discriminant_prod {τ : Type*} [Fintype τ] [LT τ] [DecidableEq τ] [∀ i, DecidablePred (fun j : τ ↦ i < j)]
  (P : τ → R[X]) :
  discriminant (∏ i, P i) = (∏ i, discriminant (P i)) * ∏ i, (∏ j ∈ {j | i < j}, (resultant (P i) (P j)) ^ 2) := by
  sorry



lemma list_prod_aux  { n : ℕ} (p : ℕ) (F : Fin n → List (ZMod p) )
  (l : List ℤ) (h : (List.prod (List.ofFn (fun i => F i))).dropTrailingZeros' = List.map (algebraMap ℤ (ZMod p)) l) :
  ∏ i, ofList (F i) = Polynomial.map (algebraMap ℤ (ZMod p)) (ofList l) := by sorry

lemma discriminant_map_lists {l : List ℤ} {p : ℕ} (hl : l.getLastD 0 = 1) (hld : ↑l.length ≠ (1 : ZMod p)) :
  algebraMap ℤ (ZMod p) (discriminant (ofList l)) = discriminant (Polynomial.map (algebraMap ℤ (ZMod p)) (ofList l)) := by sorry

/- lemma resultant_map_lists (l₁ l₂ : List ℤ) (p : ℕ) (hl1 : l₁.getLastD 0 = 1)
  (hl2 : l₂.getLastD 0 = 1) :
  algebraMap ℤ (ZMod p) (resultant (ofList l₁) (ofList l₂)) = resultant (Polynomial.map (algebraMap ℤ (ZMod p)) (ofList l)) := by sorry -/

lemma discriminant_prod_aux {n : ℕ} {P : Fin n → R[X]} (A : Matrix (Fin n) (Fin n) R)
  (h : ∀ i j, i < j → A i j = resultant (P i) (P j)) (hd : ∀ i, A i i = discriminant (P i)) :
  discriminant (∏ i, P i) = (∏ i, A i i) * (∏ i, ∏ j ∈ {j | i < j}, (A i j) ^ 2) := by sorry



